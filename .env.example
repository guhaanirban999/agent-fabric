# ---- Postgres ----
POSTGRES_USER=fabric
POSTGRES_PASSWORD=fabric
POSTGRES_DB=fabric
DATABASE_URL=postgresql+asyncpg://fabric:fabric@postgres:5432/fabric

# ---- OPA ----
OPA_URL=http://opa:8181

# ---- OpenTelemetry ----
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=agent-fabric

# ---- Registry ----
REGISTRY_URL=http://registry:8000

# ---- Gateways ----
GATEWAY_MCP_URL=http://gateway-mcp:8000
GATEWAY_A2A_URL=http://gateway-a2a:8000

# ---- Auth (dev) ----
# OIDC issuer + JWKS for token validation (Phase 2+). Leave blank to disable auth in dev.
OIDC_ISSUER=
OIDC_JWKS_URL=
OIDC_AUDIENCE=agent-fabric
# Internal signing key for token-exchange / on-behalf-of (Phase 4). Dev value only.
FABRIC_SIGNING_SECRET=dev-only-change-me

# ---- Broker LLM (Phase 3) ----
ANTHROPIC_API_KEY=
BROKER_MODEL=claude-opus-4-8

# ---- Slack chatbot frontend ----
# Bot User OAuth Token (xoxb-...) and App-Level Token (xapp-..., scope connections:write)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
BROKER_URL=http://broker:8000
# ---- Chat memory ----
CHAT_HISTORY_TURNS=8
